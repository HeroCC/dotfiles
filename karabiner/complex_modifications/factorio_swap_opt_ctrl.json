{
  "title": "Factorio: swap Control and Option",
  "rules": [
    {
      "description": "Swap Control and Option only while Factorio is frontmost",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_option"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.factorio\\.factorio$",
                "^com\\.factorio\\.Factorio$",
                "^com\\.valvesoftware\\.steam\\.games\\.427520$"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "left_option",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.factorio\\.factorio$",
                "^com\\.factorio\\.Factorio$",
                "^com\\.valvesoftware\\.steam\\.games\\.427520$"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_control",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_option"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.factorio\\.factorio$",
                "^com\\.factorio\\.Factorio$",
                "^com\\.valvesoftware\\.steam\\.games\\.427520$"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_option",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_control"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.factorio\\.factorio$",
                "^com\\.factorio\\.Factorio$",
                "^com\\.valvesoftware\\.steam\\.games\\.427520$"
              ]
            }
          ]
        }
      ]
    }
  ]
}
